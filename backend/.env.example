# App
PORT=3001
NODE_ENV=development

# Database (khi chạy trong Docker, host là tên service "postgres")
DATABASE_URL="postgresql://um_user:um_password@localhost:5432/user_management?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# S3 minio
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000/user-management-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=um_minio_admin
S3_SECRET_KEY=um_minio_password
S3_BUCKET=user-management-bucket
S3_FORCE_PATH_STYLE=true

# S3 Aws
STORAGE_DRIVER=s3
S3_ENDPOINT=                          # để trống — SDK tự build endpoint theo region
S3_PUBLIC_URL=https://user-management-bucket.s3.ap-southeast-1.amazonaws.com
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=                        # để trống — SDK tự lấy từ EC2 Instance Metadata qua IAM Role
S3_SECRET_KEY=                        # để trống
S3_BUCKET=user-management-bucket
S3_FORCE_PATH_STYLE=false

# Local storage
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./uploads
LOCAL_PUBLIC_URL=http://localhost:3001/uploads
